{
  "name": "myelinate",
  "version": "0.1.0",
  "description": "Stop paying your LLM to make the same decision twice. Crystallize repeated AI decisions into zero-cost rules.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "myelin": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test --experimental-strip-types --experimental-transform-types tests/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "triage",
    "rules",
    "crystallization",
    "llm",
    "decision",
    "optimization",
    "myelin",
    "myelinate",
    "myelination"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miles990/myelin.git"
  },
  "homepage": "https://github.com/miles990/myelin#readme",
  "bugs": {
    "url": "https://github.com/miles990/myelin/issues"
  },
  "author": "Kuro <kuro@kuro.page>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
